# ─── Telegram ─────────────────────────────────────────────
BOT_TOKEN=123456:ABCDEF_your_bot_token_here
# ID супергруппы админов (куда форвардятся сообщения от юзеров). Получить: добавить бота в группу и посмотреть update
ADMIN_GROUP_ID=-1001234567890
# Список Telegram ID админов через запятую (имеют доступ к /broadcast и команде /admin в боте)
ADMIN_IDS=111111111,222222222

# ─── Webhook / Web ────────────────────────────────────────
# Публичный URL сервиса на Railway, например https://korni-bot-production.up.railway.app
WEBHOOK_BASE_URL=https://example.up.railway.app
# Секрет в пути webhook (сгенерируй случайную строку)
WEBHOOK_SECRET=change_me_to_random_hex
# Порт (Railway выставляет сам в переменной PORT)
PORT=8080

# ─── Админ-панель (веб) ───────────────────────────────────
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_to_strong_password
# Секрет для подписи сессионных cookie
SESSION_SECRET=change_me_to_random_hex

# ─── БД ───────────────────────────────────────────────────
# Railway Postgres addon подставит сюда DATABASE_URL сам. Для локалки можно sqlite+aiosqlite:///./korni.db
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/korni
